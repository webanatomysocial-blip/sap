# api/.htaccess

# Security hardening for the PHP API directory

# Blocks direct access to sensitive files while preserving all API functionality.

# Block all access to sensitive file types

<FilesMatch "\.(sqlite|env|sql|log|zip)$">
Order Deny,Allow
Deny from all
</FilesMatch>

# Block debug, test, migration, and setup scripts from direct browser access

# (they still work via CLI or when required by other PHP files)

<FilesMatch "^(debug*|test|test*|migrate*|setup*|export*|fix*|dump|bulk_recalculate|apply_performance)">
Order Deny,Allow
Deny from all
</FilesMatch>

# Block cache directory from direct access

<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteRule ^cache/ - [F,L]
    RewriteRule ^logs/ - [F,L]
    RewriteRule ^migrations/ - [F,L]

    # Route all API requests to index.php (The Custom PHP Router)
    RewriteBase /api/
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^ index.php [QSA,L]

</IfModule>

# Block backup files

<FilesMatch "\.(bak|old|backup|orig|swp|tmp)$">
Order Deny,Allow
Deny from all
</FilesMatch>
